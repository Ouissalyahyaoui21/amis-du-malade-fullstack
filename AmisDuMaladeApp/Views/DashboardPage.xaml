<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             x:Class="AmisDuMaladeApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             FlowDirection="{Binding FlowDirection}"
             BackgroundColor="#f4f6f9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══ HEADER ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="#1a3a5c" Padding="20,50,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="{Binding TitleLabel}"
                       TextColor="White" FontSize="20" FontAttributes="Bold"/>
                <Label Text="جمعية أصدقاء المريض – سكيكدة"
                       TextColor="#c8a53a" FontSize="12"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="{Binding LogoutLabel}"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Transparent"
                    BorderColor="#c8a53a" BorderWidth="1"
                    TextColor="#c8a53a" FontSize="12"
                    CornerRadius="10"
                    HeightRequest="34" Padding="10,0"/>
        </Grid>

        <!-- ═══ DASHBOARD CONTENT ════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- Refresh button -->
                <Button Text="{Binding RefreshLabel}"
                        Command="{Binding LoadDashboardCommand}"
                        BackgroundColor="#1a3a5c"
                        TextColor="White"
                        CornerRadius="10"
                        HeightRequest="40"
                        HorizontalOptions="End"
                        WidthRequest="100"/>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#1a3a5c"
                                   HorizontalOptions="Center"/>

                <!-- ── KPI ROW 1: Volunteers + Requests ── -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Volunteers card -->
                    <Border Grid.Column="0"
                            BackgroundColor="#1a3a5c"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="👥" FontSize="24"/>
                            <Label Text="{Binding TotalVolunteers}"
                                   TextColor="#c8a53a"
                                   FontSize="28" FontAttributes="Bold"/>
                            <Label Text="{Binding VolunteersLabel}"
                                   TextColor="White" FontSize="12"/>
                            <Label TextColor="#aac8e8" FontSize="11">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding ActiveVolunteers}"/>
                                        <Span Text=" "/>
                                        <Span Text="نشط"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Requests card -->
                    <Border Grid.Column="1"
                            BackgroundColor="#0a5c46"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="📋" FontSize="24"/>
                            <Label Text="{Binding TotalRequests}"
                                   TextColor="#c8a53a"
                                   FontSize="28" FontAttributes="Bold"/>
                            <Label Text="{Binding RequestsLabel}"
                                   TextColor="White" FontSize="12"/>
                            <Label TextColor="#aad4c4" FontSize="11">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding PendingRequests}"/>
                                        <Span Text=" "/>
                                        <Span Text="معلّق"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── KPI ROW 2: Patients + Alerts ── -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Patients card -->
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,14"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🏥" FontSize="24"/>
                            <Label Text="{Binding TotalPatients}"
                                   TextColor="#1a3a5c"
                                   FontSize="28" FontAttributes="Bold"/>
                            <Label Text="{Binding PatientsLabel}"
                                   TextColor="#555" FontSize="12"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Alerts card -->
                    <Border Grid.Column="1"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,14"
                            Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🔔" FontSize="24"/>
                            <Label Text="{Binding OpenAlerts}"
                                   TextColor="#e53935"
                                   FontSize="28" FontAttributes="Bold"/>
                            <Label Text="{Binding AlertsLabel}"
                                   TextColor="#555" FontSize="12"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── KPI ROW 3: Assignments ── -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,14"
                        Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}">
                    <Grid ColumnDefinitions="*,*,*">
                        <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding ActiveAssignments}"
                                   TextColor="#1a3a5c"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding AssignmentsLabel}"
                                   TextColor="#555" FontSize="11"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" WidthRequest="1"
                                 BackgroundColor="#eee" VerticalOptions="Fill"/>
                        <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                            <Label Text="{Binding NewVolunteersThisMonth}"
                                   TextColor="#0a5c46"
                                   FontSize="22" FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <Label Text="متطوع جديد / شهر"
                                   TextColor="#555" FontSize="11"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── RECENT ACTIVITIES ── -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Padding="16"
                        Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding RecentLabel}"
                               TextColor="#1a3a5c"
                               FontSize="15" FontAttributes="Bold"/>
                        <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                                 HorizontalOptions="Start" WidthRequest="32"/>

                        <CollectionView ItemsSource="{Binding RecentActivities}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          Padding="0,6">
                                        <BoxView Grid.Column="0"
                                                 BackgroundColor="#1a3a5c"
                                                 CornerRadius="5"
                                                 HeightRequest="10" WidthRequest="10"
                                                 VerticalOptions="Center"
                                                 Margin="0,0,10,0"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding Description}"
                                               TextColor="#333" FontSize="13"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding TimeAgo}"
                                               TextColor="#999" FontSize="11"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="20" Color="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>

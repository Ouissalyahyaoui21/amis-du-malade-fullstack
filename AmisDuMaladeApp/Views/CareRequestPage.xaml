<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             x:Class="AmisDuMaladeApp.Views.CareRequestPage"
             x:DataType="vm:CareRequestViewModel"
             FlowDirection="{Binding FlowDirection}"
             BackgroundColor="#f4f6f9"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" BackgroundColor="#0a5c46" Padding="20,50,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Text="‹" TextColor="White" FontSize="28"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding PrevStepCommand}"/>
                </Label.GestureRecognizers>
            </Label>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                <Label Text="{Binding TitleLabel}"
                       TextColor="White" FontSize="16" FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding StepIndicator}"
                       TextColor="#c8a53a" FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- ═══ FORM CONTENT ════════════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- ── Confirmation screen (after submit) ──────────────── -->
                <VerticalStackLayout IsVisible="{Binding ShowSuggestions}" Spacing="12">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="✅" FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding SuggestionsTitle}"
                                   TextColor="#1a3a5c" FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                            <CollectionView ItemsSource="{Binding Suggestions}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border BackgroundColor="#f4f6f9"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="0"
                                                Margin="0,4" Padding="14,10">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="{Binding FullName}"
                                                           TextColor="#1a3a5c"
                                                           FontSize="14" FontAttributes="Bold"/>
                                                    <Label Text="{Binding Municipality}"
                                                           TextColor="#666" FontSize="12"/>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="1"
                                                       TextColor="#0a5c46"
                                                       FontSize="13" FontAttributes="Bold"
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            <Button Text="العودة للرئيسية"
                                    Command="{Binding GoBackCommand}"
                                    BackgroundColor="#1a3a5c"
                                    TextColor="White"
                                    CornerRadius="12"
                                    HeightRequest="48"
                                    Margin="0,8,0,0"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 1: Requester data ────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="12">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="{Binding Step1Label}"
                                   TextColor="#0a5c46" FontSize="15"
                                   FontAttributes="Bold"/>
                            <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                                     HorizontalOptions="Start" WidthRequest="32"/>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="الاسم الكامل" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding RequesterName}"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="رقم الهاتف" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding RequesterPhone}"
                                           Keyboard="Telephone"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="صلة القرابة بالمريض" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding RequesterRelation}"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 2: Patient data ──────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="12">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="{Binding Step2Label}"
                                   TextColor="#0a5c46" FontSize="15"
                                   FontAttributes="Bold"/>
                            <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                                     HorizontalOptions="Start" WidthRequest="32"/>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="اسم المريض" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding PatientName}"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="العمر" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding PatientAge}"
                                           Keyboard="Numeric"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="الحالة الطبية" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Editor Text="{Binding MedicalCondition}"
                                            AutoSize="TextChanges"
                                            BackgroundColor="Transparent"
                                            Margin="8,4"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 3: Request details ───────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding IsStep3}" Spacing="12">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="{Binding Step3Label}"
                                   TextColor="#0a5c46" FontSize="15"
                                   FontAttributes="Bold"/>
                            <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                                     HorizontalOptions="Start" WidthRequest="32"/>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="البلدية" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Entry Text="{Binding Municipality}"
                                           BackgroundColor="Transparent" Margin="8,0"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="تاريخ البدء" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea"
                                        Padding="8,4">
                                    <DatePicker Date="{Binding RequestedDate}"
                                                MinimumDate="{x:Static sys:DateTime.Today}"
                                                BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="4">
                                <Label Text="ملخص طبي" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Editor Text="{Binding MedicalSummary}"
                                            AutoSize="TextChanges"
                                            BackgroundColor="Transparent"
                                            Margin="8,4"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ── STEP 4: Service type ──────────────────────────── -->
                <VerticalStackLayout IsVisible="{Binding IsStep4}" Spacing="12">
                    <Border BackgroundColor="White" StrokeThickness="0"
                            StrokeShape="RoundRectangle 16" Padding="20">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="{Binding Step4Label}"
                                   TextColor="#0a5c46" FontSize="15"
                                   FontAttributes="Bold"/>
                            <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                                     HorizontalOptions="Start" WidthRequest="32"/>

                            <Grid ColumnDefinitions="*,Auto" Padding="4,0">
                                <Label Grid.Column="0" Text="زيارة منزلية"
                                       TextColor="#333" FontSize="14" VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding NeedsHomeVisit}"
                                        OnColor="#0a5c46"/>
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#eee"/>

                            <Grid ColumnDefinitions="*,Auto" Padding="4,0">
                                <Label Grid.Column="0" Text="زيارة مستشفى"
                                       TextColor="#333" FontSize="14" VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding NeedsHospitalVisit}"
                                        OnColor="#0a5c46"/>
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#eee"/>

                            <Grid ColumnDefinitions="*,Auto" Padding="4,0">
                                <Label Grid.Column="0" Text="حضور ليلي"
                                       TextColor="#333" FontSize="14" VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding NeedsNightPresence}"
                                        OnColor="#0a5c46"/>
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#eee"/>

                            <Grid ColumnDefinitions="*,Auto" Padding="4,0">
                                <Label Grid.Column="0" Text="دعم النقل"
                                       TextColor="#333" FontSize="14" VerticalOptions="Center"/>
                                <Switch Grid.Column="1" IsToggled="{Binding NeedsTransportSupport}"
                                        OnColor="#0a5c46"/>
                            </Grid>

                            <VerticalStackLayout Spacing="4" Margin="0,8,0,0">
                                <Label Text="نوع الدعم المطلوب" TextColor="#1a3a5c" FontSize="13"/>
                                <Border BackgroundColor="#f4f6f9"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="1" Stroke="#dde3ea">
                                    <Editor Text="{Binding SupportSummary}"
                                            AutoSize="TextChanges"
                                            BackgroundColor="Transparent"
                                            Margin="8,4"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BOTTOM NAVIGATION ════════════════════════════════════════ -->
        <Grid Grid.Row="2" Padding="20,12,20,28"
              BackgroundColor="White"
              ColumnDefinitions="*,*">

            <Button Grid.Column="0"
                    Text="{Binding PrevLabel}"
                    Command="{Binding PrevStepCommand}"
                    IsVisible="{Binding CanGoPrev}"
                    BackgroundColor="Transparent"
                    BorderColor="#0a5c46" BorderWidth="1.5"
                    TextColor="#0a5c46"
                    CornerRadius="12" HeightRequest="48"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="1"
                    Text="{Binding NextLabel}"
                    Command="{Binding NextStepCommand}"
                    IsVisible="{Binding CanGoNext}"
                    BackgroundColor="#0a5c46"
                    TextColor="White"
                    CornerRadius="12" HeightRequest="48"
                    Margin="8,0,0,0"/>

            <Button Grid.Column="0" Grid.ColumnSpan="2"
                    Text="{Binding SubmitLabel}"
                    Command="{Binding SubmitCommand}"
                    IsVisible="{Binding CanSubmit}"
                    BackgroundColor="#c8a53a"
                    TextColor="#1a3a5c" FontAttributes="Bold"
                    CornerRadius="12" HeightRequest="48"/>
        </Grid>

    </Grid>
</ContentPage>

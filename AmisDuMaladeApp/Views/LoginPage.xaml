<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             x:Class="AmisDuMaladeApp.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             FlowDirection="{Binding FlowDirection}"
             BackgroundColor="#1a3a5c"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="0"
                             VerticalOptions="Center"
                             MinimumHeightRequest="600">

            <!-- Logo -->
            <Border BackgroundColor="White"
                    StrokeShape="Ellipse"
                    StrokeThickness="3" Stroke="#c8a53a"
                    HeightRequest="110" WidthRequest="110"
                    HorizontalOptions="Center"
                    Margin="0,60,0,24">
                <Image Source="logo.png"
                       HeightRequest="90" WidthRequest="90"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Title -->
            <Label Text="{Binding TitleLabel}"
                   TextColor="#c8a53a"
                   FontSize="20" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"/>
            <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                     WidthRequest="48" HorizontalOptions="Center"
                     Margin="0,0,0,32"/>

            <!-- Card -->
            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Padding="24,28"
                    Shadow="{Shadow Brush=Black, Offset='0,6', Radius=20, Opacity=0.2}">
                <VerticalStackLayout Spacing="18">

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding EmailLabel}"
                               TextColor="#1a3a5c" FontSize="13"
                               FontAttributes="Bold"/>
                        <Border BackgroundColor="#f4f6f9"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1.5" Stroke="#dde3ea">
                            <Entry Text="{Binding Email}"
                                   Keyboard="Email"
                                   BackgroundColor="Transparent"
                                   HeightRequest="46"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding PasswordLabel}"
                               TextColor="#1a3a5c" FontSize="13"
                               FontAttributes="Bold"/>
                        <Border BackgroundColor="#f4f6f9"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="1.5" Stroke="#dde3ea">
                            <Entry Text="{Binding Password}"
                                   IsPassword="True"
                                   BackgroundColor="Transparent"
                                   HeightRequest="46"
                                   Margin="10,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Login button -->
                    <Button Text="{Binding LoginBtnLabel}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"
                            BackgroundColor="#1a3a5c"
                            TextColor="White"
                            FontSize="15" FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="52"
                            Margin="0,8,0,0"/>

                    <!-- Loading indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#1a3a5c"
                                       HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Back to home -->
            <Label Text="← العودة"
                   TextColor="#c8a53a"
                   FontSize="13"
                   HorizontalOptions="Center"
                   Margin="0,24,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             xmlns:m="clr-namespace:AmisDuMaladeApp.Models"
             x:Class="AmisDuMaladeApp.Views.AdminDashboardPage"
             x:DataType="vm:AdminDashboardViewModel"
             Shell.NavBarIsVisible="False"
             FlowDirection="RightToLeft"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- ══ TOP BAR ══ -->
        <Grid Grid.Row="0" BackgroundColor="#1a3a5c" Padding="18,52,18,14"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto">

            <!-- الشعار + الاسم -->
            <HorizontalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Border WidthRequest="36" HeightRequest="36" StrokeThickness="2" Stroke="#c8a53a">
                    <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                    <Image Source="logo.png" Aspect="AspectFill"/>
                </Border>
                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                    <Label Text="جمعية أصدقاء المريض" FontSize="13" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="لوحة الإدارة" FontSize="10" TextColor="#c8a53a"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!-- بادج التنبيهات -->
            <Border Grid.Column="2" BackgroundColor="#dc2626" StrokeThickness="0"
                    Padding="10,6" Margin="0,0,8,0" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="alerts"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4">
                    <Label Text="🚨" FontSize="13"/>
                    <Label Text="{Binding StatAlerts}" FontSize="13" FontAttributes="Bold" TextColor="White"/>
                </HorizontalStackLayout>
            </Border>

            <!-- الصفحة الرئيسية -->
            <Border Grid.Column="3" BackgroundColor="#0f2236" StrokeThickness="0"
                    Padding="10,6" Margin="0,0,6,0" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoHomeCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4">
                    <Label Text="🏠" FontSize="13"/>
                    <Label Text="الرئيسية" FontSize="12" TextColor="White" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>

            <!-- خروج -->
            <Border Grid.Column="4" BackgroundColor="#0f2236" StrokeThickness="0"
                    Padding="10,6" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding LogoutCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4">
                    <Label Text="🚪" FontSize="13"/>
                    <Label Text="خروج" FontSize="12" TextColor="#fca5a5" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ══ TAB STRIP ══ -->
        <ScrollView Grid.Row="1" Orientation="Horizontal" BackgroundColor="#1a3a5c"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Padding="12,0,12,0" Spacing="6">

                <!-- Helper macro: each tab is a Border + Label pair -->
                <!-- Overview -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="overview"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsOverviewTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsOverviewTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="🏠 الرئيسية" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsOverviewTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsOverviewTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Volunteers -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="volunteers"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsVolunteersTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsVolunteersTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="🤝 المتطوعون" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsVolunteersTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsVolunteersTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Interviews -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="interviews"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsInterviewsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsInterviewsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="🗣 المقابلات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsInterviewsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsInterviewsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Training -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="training"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsTrainingTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsTrainingTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="🎓 التدريبات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsTrainingTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsTrainingTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Evaluations -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="evaluations"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsEvaluationsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsEvaluationsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="⭐ التقييمات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsEvaluationsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsEvaluationsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- New Requests -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="newrequests"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNewRequestsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsNewRequestsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="🆕 جديدة" FontSize="12" FontAttributes="Bold">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsNewRequestsTab}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding IsNewRequestsTab}" Value="False">
                                    <Setter Property="TextColor" Value="#90afc8"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Border BackgroundColor="#dc2626" StrokeThickness="0" Padding="4,1" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                            <Label Text="{Binding StatPendingRequests}" FontSize="9"
                                   TextColor="White" FontAttributes="Bold"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>

                <!-- All Requests -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="requests"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsRequestsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsRequestsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="📋 الطلبات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRequestsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRequestsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Patients -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="patients"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsPatientsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsPatientsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="👥 المرضى" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPatientsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsPatientsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Alerts -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="alerts"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAlertsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#dc2626"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsAlertsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="🚨 التنبيهات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAlertsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsAlertsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Reports -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="reports"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsReportsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#c8a53a"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsReportsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="📊 التقارير" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsReportsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsReportsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

                <!-- Contributions -->
                <Border Padding="12,9" StrokeThickness="0" Margin="0,6">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="contributions"/>
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsContributionsTab}" Value="True">
                            <Setter Property="BackgroundColor" Value="#0a5c46"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsContributionsTab}" Value="False">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="💰 المساهمات" FontSize="12" FontAttributes="Bold">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsContributionsTab}" Value="True">
                                <Setter Property="TextColor" Value="White"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsContributionsTab}" Value="False">
                                <Setter Property="TextColor" Value="#90afc8"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </Border>

            </HorizontalStackLayout>
        </ScrollView>

        <!-- ══ CONTENT AREA ══ -->
        <RefreshView Grid.Row="2"
                     Command="{Binding RefreshCurrentTabCommand}"
                     IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="0,0,0,24">

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="#1a3a5c" HeightRequest="48" Margin="0,20"/>

                <!-- ══ ERROR BANNER ══ -->
                <Border IsVisible="{Binding HasLoadError}"
                        BackgroundColor="#fee2e2" StrokeThickness="0"
                        Padding="14,12" Margin="16,8,16,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <Label Grid.Column="0" Text="⚠️" FontSize="20" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding LoadErrorMessage}"
                               FontSize="12" TextColor="#991b1b"
                               LineBreakMode="WordWrap" VerticalOptions="Center"/>
                        <Border Grid.Column="2" BackgroundColor="#dc2626"
                                StrokeThickness="0" Padding="10,7" VerticalOptions="Center">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCurrentTabCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="إعادة المحاولة" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 1 — OVERVIEW
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsOverviewTab}" Spacing="12" Padding="16,16,16,0">

                    <!-- تنبيه عاجل -->
                    <Border BackgroundColor="#7c3aed" StrokeThickness="0" Padding="14,12"
                            IsVisible="{Binding StatAlerts, Converter={StaticResource IntToBoolConverter}}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="alerts"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="⚡" FontSize="22" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" Margin="10,0">
                                <Label Text="تنبيهات عاجلة تحتاج مراجعة" FontSize="13"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="اضغط لعرض التفاصيل" FontSize="11" TextColor="#ddd6fe"/>
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#dc2626" StrokeThickness="0"
                                    Padding="8,4">
                                <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                                <Label Text="{Binding StatAlerts}" FontSize="16" FontAttributes="Bold"
                                       TextColor="White" HorizontalTextAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- شبكة الإحصاء 2×3 -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10">

                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#1a3a5c"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="volunteers"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="🤝" FontSize="22"/>
                                <Label Text="{Binding StatVolunteers}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="المتطوعون" FontSize="11" TextColor="#a6c8e8"/>
                                <Label Text="{Binding StatActiveVolunteers, StringFormat='✓ نشط: {0}'}"
                                       FontSize="10" TextColor="#86efac"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#0a5c46"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="newrequests"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="📋" FontSize="22"/>
                                <Label Text="{Binding StatRequests}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="طلبات المرافقة" FontSize="11" TextColor="#a0d4c0"/>
                                <Label Text="{Binding StatPendingRequests, StringFormat='⏳ معلّق: {0}'}"
                                       FontSize="10" TextColor="#fcd34d"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#7c3aed"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="patients"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="🏥" FontSize="22"/>
                                <Label Text="{Binding StatPatients}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="المرضى" FontSize="11" TextColor="#ddd6fe"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#b45309"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="📌" FontSize="22"/>
                                <Label Text="{Binding StatAssignments}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="تكليفات نشطة" FontSize="11" TextColor="#fde68a"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" BackgroundColor="#dc2626"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="alerts"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="🚨" FontSize="22"/>
                                <Label Text="{Binding StatAlerts}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="تنبيهات مفتوحة" FontSize="11" TextColor="#fecaca"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="1" BackgroundColor="#1a5c3a"
                                StrokeThickness="0" Padding="14,12">
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="contributions"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label Text="💰" FontSize="22"/>
                                <Label Text="{Binding StatContributions}" FontSize="26"
                                       FontAttributes="Bold" TextColor="White"/>
                                <Label Text="المساهمات" FontSize="11" TextColor="#a0d4c0"/>
                                <Label Text="{Binding StatPendingContributions, StringFormat='⏳ معلّق: {0}'}"
                                       FontSize="10" TextColor="#fcd34d"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- هذا الشهر -->
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto,*">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                                <Label Text="{Binding StatNewVolunteersMonth}" FontSize="24"
                                       FontAttributes="Bold" TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                <Label Text="متطوع جديد هذا الشهر" FontSize="10"
                                       TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#e5e7eb"/>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">

                                        <Setter Property="BackgroundColor" Value="#dc2626"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding InterviewFilter}" Value="All">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding InterviewFilter}" Value="Scheduled">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding InterviewFilter}" Value="Completed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding InterviewsCountCancelled, StringFormat='❌ ملغاة ({0})'}"
                                       FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding InterviewFilter}" Value="Cancelled">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding InterviewFilter}" Value="All">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding InterviewFilter}" Value="Scheduled">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding InterviewFilter}" Value="Completed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Empty state -->
                    <Border IsVisible="{Binding HasNoInterviews}"
                            BackgroundColor="#fef3c7" StrokeThickness="0" Padding="14,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Label Text="📅 لا توجد مقابلات مجدولة حالياً"
                               FontSize="12" TextColor="#92400e" HorizontalTextAlignment="Center"/>
                    </Border>

                    <!-- Interviews list -->
                    <CollectionView ItemsSource="{Binding FilteredInterviews}" HeightRequest="560">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:VolunteerInterviewItem">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08"/></Border.Shadow>
                                    <VerticalStackLayout Spacing="10">

                                        <!-- Name + Status badge -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding VolunteerName}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" VerticalOptions="Center"/>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{Binding StatusBgColor}"
                                                    StrokeThickness="0" Padding="8,4">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <Label Text="{Binding StatusLabel}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{Binding StatusTextColor}"/>
                                            </Border>
                                        </Grid>

                                        <!-- Date + Location -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Border Grid.Column="0" BackgroundColor="#f0f4f8"
                                                    StrokeThickness="0" Padding="8,6">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📅" FontSize="12"/>
                                                    <Label Text="{Binding ScheduledAtLabel}"
                                                           FontSize="11" TextColor="#374151"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                            <Border Grid.Column="1" BackgroundColor="#f0f4f8"
                                                    StrokeThickness="0" Padding="8,6">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📍" FontSize="12"/>
                                                    <Label Text="{Binding Location}"
                                                           FontSize="11" TextColor="#374151"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>

                                        <!-- Action buttons for Scheduled interviews -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                                              IsVisible="{Binding IsScheduled}">
                                            <Border Grid.Column="0" BackgroundColor="#16a34a"
                                                    StrokeThickness="0" Padding="0,9">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RecordInterviewAcceptedCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="✓ قبول المتطوع" FontSize="11" FontAttributes="Bold"
                                                       TextColor="White" HorizontalTextAlignment="Center"/>
                                            </Border>
                                            <Border Grid.Column="1" BackgroundColor="#fee2e2"
                                                    StrokeThickness="0" Padding="0,9">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RecordInterviewRejectedCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="✗ رفض المتطوع" FontSize="11" FontAttributes="Bold"
                                                       TextColor="#dc2626" HorizontalTextAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- Cancel button (only for scheduled interviews) -->
                                        <Border IsVisible="{Binding IsScheduled}"
                                                BackgroundColor="#fff1f2" StrokeThickness="1"
                                                Stroke="#fecdd3" Padding="0,9">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.CancelInterviewCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✕ إلغاء المقابلة" FontSize="11" FontAttributes="Bold"
                                                   TextColor="#e11d48" HorizontalTextAlignment="Center"/>
                                        </Border>

                                        <!-- Result banner for completed interviews -->
                                        <Border IsVisible="{Binding IsCompleted}"
                                                BackgroundColor="{Binding ResultBgColor}"
                                                StrokeThickness="0" Padding="10,7">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Label Text="{Binding ResultLabel}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="{Binding ResultTextColor}"
                                                   HorizontalTextAlignment="Center"/>
                                        </Border>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 4 — TRAINING (placeholder content)
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsTrainingTab}" Spacing="12" Padding="16,16,16,0">

                    <!-- Header + Create button -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="🎓 الدورات التدريبية"
                               FontSize="15" FontAttributes="Bold" TextColor="#1a3a5c"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="#f0f4f8" StrokeThickness="0" Padding="10,8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshCurrentTabCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="🔄" FontSize="14" VerticalOptions="Center"/>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="12,8">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CreateTrainingCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="+ دورة جديدة" TextColor="#c8a53a"
                                   FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoadingTrainings}"
                                       IsVisible="{Binding IsLoadingTrainings}"
                                       Color="#1a3a5c" HorizontalOptions="Center"/>

                    <!-- Empty state -->
                    <Border IsVisible="{Binding HasNoTrainings}"
                            BackgroundColor="#dcfce7" StrokeThickness="0" Padding="14,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Label Text="🎓 لا توجد دورات تدريبية — اضغط على (+ دورة جديدة) لإنشاء دورة"
                               FontSize="12" TextColor="#15803d" HorizontalTextAlignment="Center"/>
                    </Border>

                    <!-- Trainings list -->
                    <CollectionView ItemsSource="{Binding TrainingsList}" HeightRequest="560">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:TrainingItem">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08"/></Border.Shadow>
                                    <VerticalStackLayout Spacing="10">

                                        <!-- Title + Capacity badge -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding Title}"
                                                   FontSize="15" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" VerticalOptions="Center"/>
                                            <Border Grid.Column="1" BackgroundColor="#e0f2fe"
                                                    StrokeThickness="0" Padding="8,4">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <Label Text="{Binding CapacityLabel}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="#0369a1"/>
                                            </Border>
                                        </Grid>

                                        <!-- Description -->
                                        <Label Text="{Binding Description}"
                                               FontSize="12" TextColor="#6b7280"/>

                                        <!-- Date + Location -->
                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                            <Border Grid.Column="0" BackgroundColor="#f0f4f8"
                                                    StrokeThickness="0" Padding="8,6">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📅" FontSize="12"/>
                                                    <Label Text="{Binding StartDateLabel}"
                                                           FontSize="11" TextColor="#374151"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                            <Border Grid.Column="1" BackgroundColor="#f0f4f8"
                                                    StrokeThickness="0" Padding="8,6">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="4">
                                                    <Label Text="📍" FontSize="12"/>
                                                    <Label Text="{Binding Location}"
                                                           FontSize="11" TextColor="#374151"
                                                           VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                        </Grid>

                                        <!-- Enroll volunteer button -->
                                        <Border BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="0,10">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EnrollVolunteerInTrainingCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="+ تسجيل متطوع في الدورة"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="#c8a53a" HorizontalTextAlignment="Center"/>
                                        </Border>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 5 — EVALUATIONS (placeholder)
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsEvaluationsTab}" Spacing="12" Padding="16,16,16,0">

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto" Padding="0,4,0,0">
                        <Label Grid.Column="0" Text="⭐ تقييمات المتطوعين"
                               FontSize="15" FontAttributes="Bold" TextColor="#1a3a5c"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Info card -->
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.08"/></Border.Shadow>
                        <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                            <Label Text="⭐" FontSize="48" HorizontalTextAlignment="Center"/>
                            <Label Text="تقييمات أداء المتطوعين" FontSize="16" FontAttributes="Bold"
                                   TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                            <Label Text="ستُعرض هنا تقييمات المرضى وذويهم لأداء المتطوعين خلال الزيارات"
                                   FontSize="13" TextColor="#6b7280" HorizontalTextAlignment="Center" LineHeight="1.4"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Stats cards -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="#fef3c7" StrokeThickness="0" Padding="16,14">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="📊" FontSize="28" HorizontalTextAlignment="Center"/>
                                <Label Text="تقييم الزيارات" FontSize="11" FontAttributes="Bold"
                                       TextColor="#92400e" HorizontalTextAlignment="Center"/>
                                <Label Text="قيد التطوير" FontSize="10" TextColor="#b45309"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#dcfce7" StrokeThickness="0" Padding="16,14">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Label Text="🏆" FontSize="28" HorizontalTextAlignment="Center"/>
                                <Label Text="أفضل المتطوعين" FontSize="11" FontAttributes="Bold"
                                       TextColor="#15803d" HorizontalTextAlignment="Center"/>
                                <Label Text="قيد التطوير" FontSize="10" TextColor="#16a34a"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Note -->
                    <Border BackgroundColor="#f0f4f8" StrokeThickness="0" Padding="14,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Label Text="💡 التقييمات تُسجَّل تلقائياً بعد كل زيارة مكتملة من قِبَل المريض أو ذويه"
                               FontSize="12" TextColor="#374151" HorizontalTextAlignment="Center"/>
                    </Border>

                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 6 — NEW REQUESTS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsNewRequestsTab}" Spacing="10" Padding="16,16,16,0">
                    <Label Text="{Binding StatPendingRequests, StringFormat='⏳ {0} طلبات تنتظر التعيين'}"
                           FontSize="13" FontAttributes="Bold" TextColor="#b45309"/>
                    <CollectionView ItemsSource="{Binding NewRequests}"
                                    HeightRequest="520">
                        <CollectionView.EmptyView>
                            <Label Text="✅ لا توجد طلبات معلقة" FontSize="13"
                                   TextColor="#9ca3af" HorizontalTextAlignment="Center" Margin="0,24"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:CareRequestListItem">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="6,*" ColumnSpacing="12">
                                        <BoxView Grid.Column="0" BackgroundColor="#dc2626"
                                                 CornerRadius="3" VerticalOptions="Fill"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                                            <Label FontSize="11" TextColor="#9ca3af">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="طالب: " FontAttributes="Bold"/>
                                                        <Span Text="{Binding RequesterName}"/>
                                                        <Span Text=" ← "/>
                                                        <Span Text="مريض: " FontAttributes="Bold"/>
                                                        <Span Text="{Binding PatientName}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label FontSize="11" TextColor="#6b7280">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="📅 "/>
                                                        <Span Text="{Binding CreatedAt, StringFormat='{0:dd/MM/yyyy}'}"/>
                                                        <Span Text="   "/>
                                                        <Span Text="{Binding PriorityLabel}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Border BackgroundColor="#1a3a5c" StrokeThickness="0"
                                                    Padding="10,6" HorizontalOptions="End">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenAssignPopupCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="🤝 تعيين متطوع" FontSize="12"
                                                       TextColor="White" FontAttributes="Bold"/>
                                            </Border>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 7 — ALL REQUESTS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsRequestsTab}" Spacing="10" Padding="16,16,16,0">
                    <Label Text="{Binding StatRequests, StringFormat='📋 إجمالي الطلبات: {0}'}"
                           FontSize="13" FontAttributes="Bold" TextColor="#1a3a5c"/>
                    <CollectionView ItemsSource="{Binding AllRequests}"
                                    HeightRequest="640">
                        <CollectionView.EmptyView>
                            <Label Text="لا توجد طلبات" FontSize="13"
                                   TextColor="#9ca3af" HorizontalTextAlignment="Center" Margin="0,24"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:CareRequestListItem">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,8">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label FontSize="13" FontAttributes="Bold" TextColor="#1a3a5c">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding RequesterName}"/>
                                                        <Span Text=" ← "/>
                                                        <Span Text="{Binding PatientName}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="{Binding CreatedAt, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                                   FontSize="11" TextColor="#9ca3af"/>
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1" StrokeThickness="0" Padding="8,4"
                                                VerticalOptions="Center">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Border.BackgroundColor>
                                                <Binding Path="StatusColor"/>
                                            </Border.BackgroundColor>
                                            <Label Text="{Binding StatusLabel}" FontSize="11"
                                                   TextColor="White" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 8 — PATIENTS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsPatientsTab}" Spacing="10" Padding="16,16,16,0">
                    <Label Text="{Binding StatPatients, StringFormat='👥 إجمالي المرضى: {0}'}"
                           FontSize="13" FontAttributes="Bold" TextColor="#1a3a5c"/>

                    <Border BackgroundColor="White" StrokeThickness="0" Padding="12,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="🔍" FontSize="14" VerticalOptions="Center" Margin="0,0,6,0"/>
                            <Entry Grid.Column="1" Text="{Binding PatientSearchText}"
                                   Placeholder="بحث بالاسم أو البلدية..." FontSize="13"
                                   TextColor="#1a3a5c" PlaceholderColor="#9ca3af"/>
                        </Grid>
                    </Border>

                    <CollectionView ItemsSource="{Binding FilteredPatients}"
                                    HeightRequest="480">
                        <CollectionView.EmptyView>
                            <Label Text="لا يوجد مرضى مسجلون" FontSize="13"
                                   TextColor="#9ca3af" HorizontalTextAlignment="Center" Margin="0,24"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:PatientResponse">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,8">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewPatientCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                        <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                                                BackgroundColor="#1a3a5c" StrokeThickness="0">
                                            <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                                            <Label Text="{Binding FullName, Converter={StaticResource FirstCharConverter}}"
                                                   FontSize="18" FontAttributes="Bold" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding FullName}" FontSize="14"
                                                   FontAttributes="Bold" TextColor="#1a3a5c"/>
                                            <Label FontSize="11" TextColor="#6b7280">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="📍 "/><Span Text="{Binding Municipality}"/>
                                                        <Span Text="   👤 "/><Span Text="{Binding Age, StringFormat='{0} سنة'}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="{Binding Phone, StringFormat='📱 {0}'}"
                                                   FontSize="11" TextColor="#6b7280"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 9 — ALERTS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsAlertsTab}" Spacing="10" Padding="16,16,16,0">
                    <Label Text="{Binding StatAlerts, StringFormat='🚨 {0} تنبيه مفتوح'}"
                           FontSize="13" FontAttributes="Bold" TextColor="#dc2626"/>
                    <CollectionView ItemsSource="{Binding OpenAlertsList}"
                                    HeightRequest="420">
                        <CollectionView.EmptyView>
                            <Border BackgroundColor="#dcfce7" StrokeThickness="0" Padding="16">
                                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                <Label Text="✅ لا توجد تنبيهات مفتوحة — كل شيء على ما يرام"
                                       FontSize="13" TextColor="#15803d" HorizontalTextAlignment="Center"/>
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:AlertResponse">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="0,0,0,8">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="6,*,Auto" ColumnSpacing="12">
                                        <BoxView Grid.Column="0" BackgroundColor="#dc2626"
                                                 CornerRadius="3" VerticalOptions="Fill"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{Binding Title}" FontSize="14"
                                                   FontAttributes="Bold" TextColor="#dc2626"/>
                                            <Label Text="{Binding Description}" FontSize="12"
                                                   TextColor="#6b7280" LineBreakMode="WordWrap"/>
                                            <Label Text="{Binding CreatedAt, StringFormat='📅 {0:dd/MM/yyyy HH:mm}'}"
                                                   FontSize="10" TextColor="#9ca3af"/>
                                        </VerticalStackLayout>
                                        <Border Grid.Column="2" BackgroundColor="#16a34a"
                                                StrokeThickness="0" Padding="10,7" VerticalOptions="Center">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ResolveAlertCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✓ حلّ" FontSize="12" TextColor="White" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 10 — REPORTS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsReportsTab}" Spacing="12" Padding="16,16,16,0">

                    <!-- ملخص رقمي -->
                    <Border BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto,*,Auto,*" ColumnSpacing="0">
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding StatVolunteers}" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="متطوع" FontSize="10" TextColor="#a6c8e8"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#ffffff30" Margin="0,4"/>
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding StatRequests}" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="طلب" FontSize="10" TextColor="#a6c8e8"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                            <BoxView Grid.Column="3" WidthRequest="1" BackgroundColor="#ffffff30" Margin="0,4"/>
                            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding StatPatients}" FontSize="22" FontAttributes="Bold"
                                       TextColor="White" HorizontalTextAlignment="Center"/>
                                <Label Text="مريض" FontSize="10" TextColor="#a6c8e8"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- نسبة نشاط المتطوعين -->
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📊 نسبة النشاط" FontSize="14" FontAttributes="Bold" TextColor="#1a3a5c"/>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="نشط" FontSize="12" TextColor="#6b7280" VerticalOptions="Center"/>
                                <Border Grid.Column="1" BackgroundColor="#f1f5f9" StrokeThickness="0" HeightRequest="10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                    <Border BackgroundColor="#16a34a" StrokeThickness="0" HorizontalOptions="Start"
                                            WidthRequest="{Binding ActiveBarWidth}" HeightRequest="10">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                    </Border>
                                </Border>
                                <Label Grid.Column="2" Text="{Binding StatActiveVolunteers}" FontSize="12"
                                       FontAttributes="Bold" TextColor="#1a3a5c" VerticalOptions="Center"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Label Grid.Column="0" Text="معلق" FontSize="12" TextColor="#6b7280" VerticalOptions="Center"/>
                                <Border Grid.Column="1" BackgroundColor="#f1f5f9" StrokeThickness="0" HeightRequest="10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                    <Border BackgroundColor="#f59e0b" StrokeThickness="0" HorizontalOptions="Start"
                                            WidthRequest="{Binding PendingBarWidth}" HeightRequest="10">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="5"/></Border.StrokeShape>
                                    </Border>
                                </Border>
                                <Label Grid.Column="2" Text="{Binding StatPendingVolunteers}" FontSize="12"
                                       FontAttributes="Bold" TextColor="#1a3a5c" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- هذا الشهر -->
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="10">
                            <Label Text="📈 هذا الشهر" FontSize="14" FontAttributes="Bold" TextColor="#1a3a5c"/>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border Grid.Column="0" BackgroundColor="#f0f9ff" StrokeThickness="0" Padding="12,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="{Binding StatNewVolunteersMonth}" FontSize="22"
                                               FontAttributes="Bold" TextColor="#1a3a5c"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="متطوع جديد" FontSize="11" TextColor="#6b7280"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="#f0fdf4" StrokeThickness="0" Padding="12,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                    <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                        <Label Text="{Binding StatNewRequestsMonth}" FontSize="22"
                                               FontAttributes="Bold" TextColor="#0a5c46"
                                               HorizontalTextAlignment="Center"/>
                                        <Label Text="طلب جديد" FontSize="11" TextColor="#6b7280"
                                               HorizontalTextAlignment="Center"/>
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ═══════════════════════════════════════════════════════════
                     TAB 11 — CONTRIBUTIONS
                ════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout IsVisible="{Binding IsContributionsTab}" Spacing="12" Padding="16,16,16,0">

                    <!-- ملخص مالي -->
                    <Border BackgroundColor="#0a5c46" StrokeThickness="0" Padding="16,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="0">
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="{Binding StatContributions}" FontSize="24"
                                           FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center"/>
                                    <Label Text="إجمالي" FontSize="10" TextColor="#a0d4c0"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                                <BoxView Grid.Column="1" WidthRequest="1" BackgroundColor="#ffffff20" Margin="0,4"/>
                                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                    <Label Text="{Binding StatPendingContributions}" FontSize="24"
                                           FontAttributes="Bold" TextColor="#fcd34d" HorizontalTextAlignment="Center"/>
                                    <Label Text="تنتظر التأكيد" FontSize="10" TextColor="#a0d4c0"
                                           HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                            <BoxView HeightRequest="1" BackgroundColor="#ffffff20"/>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding StatTotalAmountCollected, StringFormat='💰 {0:N0} دج'}" FontSize="22"
                                       FontAttributes="Bold" TextColor="#86efac" HorizontalTextAlignment="Center"/>
                                <Label Text="إجمالي المبالغ المحصَّلة (مؤكدة + موزَّعة)" FontSize="10" TextColor="#a0d4c0"
                                       HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- فلتر الحالة -->
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8">
                            <Border Padding="12,7" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding FilterContributionsCommand}" CommandParameter="All"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="All">
                                        <Setter Property="BackgroundColor" Value="#0a5c46"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Pending">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Distributed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="الكل" FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="All">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Pending">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Distributed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                            <Border Padding="12,7" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding FilterContributionsCommand}" CommandParameter="Pending"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Pending">
                                        <Setter Property="BackgroundColor" Value="#b45309"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="All">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Distributed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="⏳ معلقة" FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Pending">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="All">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Distributed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                            <Border Padding="12,7" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding FilterContributionsCommand}" CommandParameter="Confirmed"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                        <Setter Property="BackgroundColor" Value="#16a34a"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="All">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Pending">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Distributed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="✅ مؤكدة" FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="All">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Pending">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Distributed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                            <Border Padding="12,7" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding FilterContributionsCommand}" CommandParameter="Distributed"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Distributed">
                                        <Setter Property="BackgroundColor" Value="#64748b"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="All">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Pending">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                        <Setter Property="BackgroundColor" Value="White"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="📤 موزَّعة" FontSize="12" FontAttributes="Bold">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Distributed">
                                            <Setter Property="TextColor" Value="White"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="All">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Pending">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding ContributionFilter}" Value="Confirmed">
                                            <Setter Property="TextColor" Value="#6b7280"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- بحث -->
                    <Border BackgroundColor="White" StrokeThickness="0" Padding="12,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="🔍" FontSize="14" VerticalOptions="Center" Margin="0,0,6,0"/>
                            <Entry Grid.Column="1" Text="{Binding ContributionSearchText}"
                                   Placeholder="بحث بالاسم أو الهاتف..." FontSize="13"
                                   TextColor="#1a3a5c" PlaceholderColor="#9ca3af"/>
                        </Grid>
                    </Border>

                    <!-- قائمة المساهمات -->
                    <CollectionView ItemsSource="{Binding FilteredContributions}"
                                    HeightRequest="480">
                        <CollectionView.EmptyView>
                            <Label Text="لا توجد مساهمات مسجلة" FontSize="13"
                                   TextColor="#9ca3af" HorizontalTextAlignment="Center" Margin="0,24"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:ContributionItem">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="0,0,14,0" Margin="0,0,0,10">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="6,*" ColumnSpacing="12">
                                        <!-- خط ملون حسب النوع -->
                                        <Border Grid.Column="0" BackgroundColor="{Binding TypeColor}"
                                                StrokeThickness="0" VerticalOptions="Fill">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="3,0,0,3"/>
                                            </Border.StrokeShape>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="7" Padding="0,12,0,12">
                                            <!-- الاسم + الحالة -->
                                            <Grid ColumnDefinitions="*,Auto">
                                                <Label Grid.Column="0" Text="{Binding ContributorName}"
                                                       FontSize="14" FontAttributes="Bold" TextColor="#1a3a5c"/>
                                                <Border Grid.Column="1" StrokeThickness="0" Padding="7,3">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                                    <Border.BackgroundColor>
                                                        <Binding Path="StatusColor"/>
                                                    </Border.BackgroundColor>
                                                    <Label Text="{Binding StatusLabel}" FontSize="10"
                                                           TextColor="White" FontAttributes="Bold"/>
                                                </Border>
                                            </Grid>
                                            <!-- الهاتف + النوع -->
                                            <HorizontalStackLayout Spacing="8">
                                                <Border BackgroundColor="{Binding TypeColor}" StrokeThickness="0"
                                                        Padding="7,3" Opacity="0.15">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                                </Border>
                                                <Label Text="{Binding TypeLabel}" FontSize="11"
                                                       FontAttributes="Bold" TextColor="{Binding TypeColor}"/>
                                                <Label Text="·" FontSize="11" TextColor="#9ca3af"/>
                                                <Label Text="{Binding Phone}" FontSize="11" TextColor="#6b7280"/>
                                            </HorizontalStackLayout>
                                            <!-- المبلغ / الوصف -->
                                            <Label Text="{Binding Amount, StringFormat='{0} دج'}" FontSize="15"
                                                   FontAttributes="Bold" TextColor="#1a3a5c"
                                                   IsVisible="{Binding Amount, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <Label Text="{Binding Description}" FontSize="12"
                                                   TextColor="#6b7280" LineBreakMode="WordWrap"
                                                   IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <!-- فئة النشاط + طريقة الدفع -->
                                            <Label Text="{Binding ActivityCategory, StringFormat='🎯 {0}'}" FontSize="11"
                                                   TextColor="#475569"
                                                   IsVisible="{Binding ActivityCategory, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <Label Text="{Binding PaymentMethod, StringFormat='💳 {0}'}" FontSize="11"
                                                   TextColor="#475569"
                                                   IsVisible="{Binding PaymentMethod, Converter={StaticResource StringNotEmptyConverter}}"/>
                                            <!-- الرسالة -->
                                            <Label FontSize="11" TextColor="#9ca3af" FontAttributes="Italic"
                                                   LineBreakMode="WordWrap"
                                                   IsVisible="{Binding Message, Converter={StaticResource StringNotEmptyConverter}}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="&quot;"/>
                                                        <Span Text="{Binding Message}"/>
                                                        <Span Text="&quot;"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <!-- التاريخ + الأزرار -->
                                            <Label Text="{Binding CreatedAt, StringFormat='📅 {0:dd/MM/yyyy}'}"
                                                   FontSize="10" TextColor="#94a3b8"/>
                                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                <!-- واتساب -->
                                                <Border Grid.Column="0" BackgroundColor="#25d366"
                                                        StrokeThickness="0" Padding="0,9">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ContactWhatsAppCommand}"
                                                            CommandParameter="{Binding Phone}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="💬 واتساب" FontSize="11" FontAttributes="Bold"
                                                           TextColor="White" HorizontalTextAlignment="Center"/>
                                                </Border>
                                                <!-- تأكيد -->
                                                <Border Grid.Column="1" BackgroundColor="#1a3a5c"
                                                        StrokeThickness="0" Padding="0,9"
                                                        IsVisible="{Binding CanConfirm}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ConfirmContributionCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="✓ تأكيد" FontSize="11" FontAttributes="Bold"
                                                           TextColor="White" HorizontalTextAlignment="Center"/>
                                                </Border>
                                                <!-- توزيع -->
                                                <Border Grid.Column="2" BackgroundColor="#0a5c46"
                                                        StrokeThickness="0" Padding="0,9"
                                                        IsVisible="{Binding CanDistribute}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DistributeContributionCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="📦 توزيع" FontSize="11" FontAttributes="Bold"
                                                           TextColor="White" HorizontalTextAlignment="Center"/>
                                                </Border>
                                                <!-- تم التوزيع -->
                                                <Border Grid.Column="1" Grid.ColumnSpan="2" BackgroundColor="#e2e8f0"
                                                        StrokeThickness="0" Padding="0,9"
                                                        IsVisible="{Binding IsDistributed}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="11"/></Border.StrokeShape>
                                                    <Label Text="✅ تم التوزيع" FontSize="11" FontAttributes="Bold"
                                                           TextColor="#64748b" HorizontalTextAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
        </RefreshView>

        <!-- ══ ASSIGN VOLUNTEER POPUP ══ -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsAssignPopupVisible}"
              BackgroundColor="#80000000">
            <Border BackgroundColor="White" StrokeThickness="0"
                    Padding="0" Margin="16,60"
                    VerticalOptions="Center" HorizontalOptions="Fill">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="0">

                    <!-- Header -->
                    <Grid BackgroundColor="#1a3a5c" Padding="18,16" ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="🤝 تعيين متطوع"
                               FontSize="15" FontAttributes="Bold" TextColor="White"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="1" BackgroundColor="#ffffff20" StrokeThickness="0"
                                Padding="8,4">
                            <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseAssignPopupCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="✕" FontSize="14" TextColor="White" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- Request info -->
                    <VerticalStackLayout Padding="16,12" Spacing="4"
                                         BackgroundColor="#f0f4f8">
                        <Label Text="الطلب:" FontSize="11" TextColor="#6b7280"/>
                        <Label Text="{Binding SelectedRequest.RequesterName, StringFormat='طالب: {0}'}"
                               FontSize="12" TextColor="#1a3a5c" FontAttributes="Bold"/>
                        <Label Text="{Binding SelectedRequest.PatientName, StringFormat='مريض: {0}'}"
                               FontSize="12" TextColor="#374151"/>
                    </VerticalStackLayout>

                    <!-- Loading suggestions -->
                    <ActivityIndicator IsVisible="{Binding IsLoadingSuggestions}"
                                       IsRunning="{Binding IsLoadingSuggestions}"
                                       Color="#1a3a5c" HeightRequest="44" Margin="0,8"/>

                    <!-- Suggestions list -->
                    <CollectionView ItemsSource="{Binding Suggestions}"
                                    MaximumHeightRequest="320"
                                    Margin="0,0,0,0">
                        <CollectionView.EmptyView>
                            <Label Text="لا توجد مقترحات متاحة حالياً"
                                   FontSize="13" TextColor="#9ca3af"
                                   HorizontalTextAlignment="Center" Margin="0,20"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:VolunteerSuggestion">
                                <Border BackgroundColor="White" StrokeThickness="0"
                                        Padding="14,12" Margin="12,4">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <!-- نقاط التوافق -->
                                        <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                                BackgroundColor="#1a3a5c" StrokeThickness="0">
                                            <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                                            <Label Text="{Binding MatchScore, StringFormat='{0:F0}%'}"
                                                   FontSize="10" FontAttributes="Bold" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   HorizontalTextAlignment="Center"/>
                                        </Border>
                                        <!-- بيانات المتطوع -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="13"
                                                   FontAttributes="Bold" TextColor="#1a3a5c"/>
                                            <Label Text="{Binding Municipality, StringFormat='📍 {0}'}"
                                                   FontSize="11" TextColor="#6b7280"/>
                                            <Label Text="{Binding Phone, StringFormat='📞 {0}'}"
                                                   FontSize="11" TextColor="#6b7280"/>
                                            <Label Text="{Binding ReasonsText}" FontSize="10"
                                                   TextColor="#16a34a" Margin="0,2,0,0"/>
                                        </VerticalStackLayout>
                                        <!-- زر التعيين -->
                                        <Border Grid.Column="2" BackgroundColor="#16a34a"
                                                StrokeThickness="0" Padding="10,7" VerticalOptions="Center">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AssignVolunteerCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="تعيين" FontSize="12" TextColor="White" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Footer -->
                    <Border BackgroundColor="#f8fafc" StrokeThickness="0" Padding="16,12">
                        <Label Text="💡 مرتّبة حسب درجة التوافق مع الطلب"
                               FontSize="11" TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             x:Class="AmisDuMaladeApp.Views.HomePage"
             x:DataType="vm:HomeViewModel"
             FlowDirection="{Binding FlowDirection}"
             BackgroundColor="#f4f6f9"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ HEADER ════════════════════════════════════════════════ -->
            <Grid BackgroundColor="#1a3a5c" Padding="20,50,20,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Language switcher top-right (RTL: top-left) -->
                <HorizontalStackLayout Grid.Row="0" HorizontalOptions="End" Spacing="6">
                    <Button Text="ع"
                            Command="{Binding SetLanguageCommand}"
                            CommandParameter="ar"
                            BackgroundColor="#c8a53a"
                            TextColor="White"
                            FontSize="13" FontAttributes="Bold"
                            CornerRadius="14"
                            HeightRequest="28" WidthRequest="34"
                            Padding="0"/>
                    <Button Text="Fr"
                            Command="{Binding SetLanguageCommand}"
                            CommandParameter="fr"
                            BackgroundColor="Transparent"
                            BorderColor="#c8a53a" BorderWidth="1"
                            TextColor="White"
                            FontSize="11"
                            CornerRadius="14"
                            HeightRequest="28" WidthRequest="34"
                            Padding="0"/>
                    <Button Text="En"
                            Command="{Binding SetLanguageCommand}"
                            CommandParameter="en"
                            BackgroundColor="Transparent"
                            BorderColor="#c8a53a" BorderWidth="1"
                            TextColor="White"
                            FontSize="11"
                            CornerRadius="14"
                            HeightRequest="28" WidthRequest="34"
                            Padding="0"/>
                </HorizontalStackLayout>

                <!-- Logo + Title -->
                <VerticalStackLayout Grid.Row="1" HorizontalOptions="Center"
                                     Spacing="12" Margin="0,16,0,0">
                    <Border BackgroundColor="White"
                            StrokeShape="Ellipse"
                            StrokeThickness="3"
                            Stroke="#c8a53a"
                            HeightRequest="110" WidthRequest="110"
                            HorizontalOptions="Center">
                        <Image Source="logo.png"
                               HeightRequest="90" WidthRequest="90"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label Text="{Binding SubtitleText}"
                           TextColor="#c8a53a"
                           FontSize="17" FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding WelcomeText}"
                           TextColor="White"
                           FontSize="13"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- ═══ MAIN ACTION BUTTONS ═══════════════════════════════════ -->
            <VerticalStackLayout Padding="20,24,20,8" Spacing="14">

                <!-- Volunteer button -->
                <Border BackgroundColor="#1a3a5c"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Shadow="{Shadow Brush=Black, Offset='0,3', Radius=8, Opacity=0.15}">
                    <Grid Padding="18,16" ColumnDefinitions="48,*,24">
                        <Border Grid.Column="0"
                                BackgroundColor="#c8a53a"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                HeightRequest="42" WidthRequest="42">
                            <Label Text="🤝" FontSize="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0">
                            <Label Text="{Binding VolunteerBtnText}"
                                   TextColor="White"
                                   FontSize="15" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›"
                               TextColor="#c8a53a" FontSize="24"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToVolunteerRegisterCommand}"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- Care request button -->
                <Border BackgroundColor="#0a5c46"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Shadow="{Shadow Brush=Black, Offset='0,3', Radius=8, Opacity=0.15}">
                    <Grid Padding="18,16" ColumnDefinitions="48,*,24">
                        <Border Grid.Column="0"
                                BackgroundColor="#c8a53a"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                HeightRequest="42" WidthRequest="42">
                            <Label Text="🏥" FontSize="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0">
                            <Label Text="{Binding CareBtnText}"
                                   TextColor="White"
                                   FontSize="15" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›"
                               TextColor="#c8a53a" FontSize="24"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToCareRequestCommand}"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

                <!-- Contribute button -->
                <Border BackgroundColor="#c8a53a"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        Shadow="{Shadow Brush=Black, Offset='0,3', Radius=8, Opacity=0.15}">
                    <Grid Padding="18,16" ColumnDefinitions="48,*,24">
                        <Border Grid.Column="0"
                                BackgroundColor="#1a3a5c"
                                StrokeShape="RoundRectangle 10"
                                StrokeThickness="0"
                                HeightRequest="42" WidthRequest="42">
                            <Label Text="❤️" FontSize="22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" Margin="14,0">
                            <Label Text="{Binding ContributeBtnText}"
                                   TextColor="#1a3a5c"
                                   FontSize="15" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›"
                               TextColor="#1a3a5c" FontSize="24"
                               VerticalOptions="Center"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToContributeCommand}"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!-- ═══ ABOUT SECTION ════════════════════════════════════════ -->
            <Border Margin="20,8,20,8"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    Shadow="{Shadow Brush=Black, Offset='0,2', Radius=6, Opacity=0.08}">
                <VerticalStackLayout Padding="20">
                    <Label Text="{Binding AboutText}"
                           TextColor="#1a3a5c"
                           FontSize="15" FontAttributes="Bold"/>
                    <BoxView HeightRequest="2" BackgroundColor="#c8a53a"
                             HorizontalOptions="Start" WidthRequest="36"
                             Margin="0,6,0,10"/>
                    <Label Text="{Binding AboutBodyText}"
                           TextColor="#555555"
                           FontSize="13"
                           LineHeight="1.7"/>
                </VerticalStackLayout>
            </Border>

            <!-- ═══ ADMIN LOGIN LINK ══════════════════════════════════════ -->
            <Label Text="{Binding AdminLoginText}"
                   TextColor="#1a3a5c"
                   FontSize="13"
                   TextDecorations="Underline"
                   HorizontalOptions="Center"
                   Margin="0,8,0,32">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoToAdminLoginCommand}"/>
                </Label.GestureRecognizers>
            </Label>

        </VerticalStackLayout>
    </ScrollView>

    <!-- Loading overlay -->
    <ContentPage.Triggers>
        <DataTrigger TargetType="ContentPage"
                     Binding="{Binding IsBusy}"
                     Value="True">
            <Setter Property="IsEnabled" Value="False"/>
        </DataTrigger>
    </ContentPage.Triggers>

</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             xmlns:conv="clr-namespace:AmisDuMaladeApp.Converters"
             x:Class="AmisDuMaladeApp.Views.VolunteerDetailPage"
             x:DataType="vm:VolunteerDetailViewModel"
             Shell.NavBarIsVisible="False"
             FlowDirection="RightToLeft"
             BackgroundColor="#f0f4f8">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" BackgroundColor="#1a3a5c" Padding="18,52,18,18"
              ColumnDefinitions="Auto,*">
            <Border Grid.Column="0" BackgroundColor="#ffffff20" StrokeThickness="0"
                    Padding="10,8" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="→ رجوع" FontSize="13" TextColor="White" FontAttributes="Bold"/>
            </Border>
            <Label Grid.Column="1" Text="ملف المتطوع" FontSize="17" FontAttributes="Bold"
                   TextColor="White" HorizontalTextAlignment="Center" VerticalOptions="Center"/>
        </Grid>

        <!-- ══ CONTENT ══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="14" Padding="16,16,16,8">

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="#1a3a5c" HeightRequest="48" Margin="0,20"/>

                <!-- البطاقة الرئيسية -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="20,18"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">

                        <!-- الاسم + الحالة -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                            <!-- Avatar -->
                            <Border Grid.Column="0" WidthRequest="60" HeightRequest="60"
                                    BackgroundColor="#1a3a5c" StrokeThickness="0">
                                <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                                <Label Text="{Binding Volunteer.FullName, Converter={StaticResource FirstCharConverter}}"
                                       FontSize="24" FontAttributes="Bold" TextColor="White"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Volunteer.FullName}"
                                       FontSize="18" FontAttributes="Bold" TextColor="#1a3a5c"
                                       LineBreakMode="WordWrap"/>
                                <Border StrokeThickness="0" Padding="8,3" HorizontalOptions="Start"
                                        BackgroundColor="{Binding StatusBg}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                    <Label Text="{Binding StatusLabel}" FontSize="12" FontAttributes="Bold"
                                           TextColor="{Binding StatusColor}"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView BackgroundColor="#f1f5f9" HeightRequest="1"/>

                        <!-- المعلومات الشخصية -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="المعلومات الشخصية" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1a3a5c"/>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" RowSpacing="8"
                                  RowDefinitions="Auto,Auto,Auto,Auto">

                                <Label Grid.Row="0" Grid.Column="0" Text="📱" FontSize="16"/>
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Volunteer.Phone}"
                                       FontSize="13" TextColor="#374151" VerticalOptions="Center"/>

                                <Label Grid.Row="1" Grid.Column="0" Text="📍" FontSize="16"/>
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding Volunteer.Municipality}"
                                       FontSize="13" TextColor="#374151" VerticalOptions="Center"/>

                                <Label Grid.Row="2" Grid.Column="0" Text="🏷️" FontSize="16"/>
                                <Label Grid.Row="2" Grid.Column="1"
                                       Text="{Binding Volunteer.VolunteerCategory}"
                                       FontSize="13" TextColor="#374151" VerticalOptions="Center"/>

                                <Label Grid.Row="3" Grid.Column="0" Text="📅" FontSize="16"/>
                                <Label Grid.Row="3" Grid.Column="1"
                                       Text="{Binding Volunteer.CreatedAt, StringFormat='تاريخ التسجيل: {0:dd/MM/yyyy}'}"
                                       FontSize="13" TextColor="#374151" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>

                        <BoxView BackgroundColor="#f1f5f9" HeightRequest="1"/>

                        <!-- قدرات التطوع -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="قدرات التطوع" FontSize="13" FontAttributes="Bold"
                                   TextColor="#1a3a5c"/>
                            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Start">

                                <Border BackgroundColor="#e0f2fe" StrokeThickness="0" Padding="10,6"
                                        Margin="0,0,8,8"
                                        IsVisible="{Binding Volunteer.CanHospitalVisit}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🏥 زيارة مستشفى" FontSize="12" TextColor="#0369a1" FontAttributes="Bold"/>
                                </Border>

                                <Border BackgroundColor="#dcfce7" StrokeThickness="0" Padding="10,6"
                                        Margin="0,0,8,8"
                                        IsVisible="{Binding Volunteer.CanHomeVisit}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🏠 زيارة منزلية" FontSize="12" TextColor="#15803d" FontAttributes="Bold"/>
                                </Border>

                                <Border BackgroundColor="#fef3c7" StrokeThickness="0" Padding="10,6"
                                        Margin="0,0,8,8"
                                        IsVisible="{Binding Volunteer.HasTransportation}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🚗 لديه وسيلة نقل" FontSize="12" TextColor="#92400e" FontAttributes="Bold"/>
                                </Border>

                                <Border BackgroundColor="#ede9fe" StrokeThickness="0" Padding="10,6"
                                        Margin="0,0,8,8"
                                        IsVisible="{Binding Volunteer.CanNightPresence}">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                    <Label Text="🌙 حضور ليلي" FontSize="12" TextColor="#6d28d9" FontAttributes="Bold"/>
                                </Border>

                            </FlexLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ ACTION BUTTONS ══ -->
        <Grid Grid.Row="2" BackgroundColor="White" Padding="16,12"
              ColumnDefinitions="*,*,*" ColumnSpacing="10">
            <Border Grid.Column="0" BackgroundColor="#25d366" StrokeThickness="0" Padding="0,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ContactWhatsAppCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="💬 واتساب" FontSize="12" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
            </Border>
            <Border Grid.Column="1" BackgroundColor="#16a34a" StrokeThickness="0" Padding="0,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ApproveCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="✓ قبول" FontSize="12" FontAttributes="Bold"
                       TextColor="White" HorizontalTextAlignment="Center"/>
            </Border>
            <Border Grid.Column="2" BackgroundColor="#fee2e2" StrokeThickness="0" Padding="0,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RejectCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="✗ رفض" FontSize="12" FontAttributes="Bold"
                       TextColor="#dc2626" HorizontalTextAlignment="Center"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>

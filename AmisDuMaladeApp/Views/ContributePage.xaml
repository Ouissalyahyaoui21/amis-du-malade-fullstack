<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AmisDuMaladeApp.Views.ContributePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
    x:DataType="vm:ContributeViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#f0ebe3"
    FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ HEADER ══ -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="#1a3a5c"
                             Padding="16,44,16,20" Spacing="8">
            <Grid ColumnDefinitions="36,*,36">
                <!-- شعار + عنوان -->
                <HorizontalStackLayout Grid.Column="1" Spacing="10"
                                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Border WidthRequest="52" HeightRequest="52"
                            BackgroundColor="White" StrokeThickness="2"
                            Stroke="#c8a53a">
                        <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                        <Image Source="logo.png" WidthRequest="44" HeightRequest="44"
                               Aspect="AspectFill"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label Text="المساهمة في الجمعية"
                               TextColor="White" FontSize="18" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                        <Label Text="Association Amis du Malade – Skikda"
                               TextColor="#c8a53a" FontSize="12"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
                <!-- زر الرجوع -->
                <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#26ffffff" StrokeThickness="0" StrokeShape="RoundRectangle 10"
                        HorizontalOptions="Start">
                    <Label Text="‹" TextColor="White" FontSize="22"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoHomeCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <!-- حبة ساهم معنا -->
            <Border BackgroundColor="#1affffff" StrokeThickness="1"
                    Stroke="#80c8a53a" StrokeShape="RoundRectangle 20"
                    HorizontalOptions="Center" Padding="18,6">
                <Label Text="ساهم معنا 💛" TextColor="White"
                       FontSize="14" FontAttributes="Bold"/>
            </Border>
        </VerticalStackLayout>

        <!-- ══ CONTENT ══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- موجة الانتقال -->
                <Grid HeightRequest="32" BackgroundColor="#1a3a5c">
                    <Border BackgroundColor="#f0ebe3"
                            StrokeThickness="0"
                            VerticalOptions="End" HeightRequest="32">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="24,24,0,0"/>
                        </Border.StrokeShape>
                    </Border>
                </Grid>

                <VerticalStackLayout Padding="14,16,14,16" Spacing="14">

                    <!-- مؤشر الخطوات -->
                    <VerticalStackLayout Spacing="4" Margin="4,0">
                        <Grid ColumnDefinitions="38,*,38,*,38" VerticalOptions="Center">
                            <!-- خطوة 1 ✓ -->
                            <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="#1a3a5c" StrokeThickness="0" StrokeShape="RoundRectangle 19">
                                <Label Text="✓" TextColor="White" FontSize="15" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <BoxView Grid.Column="1" HeightRequest="3" BackgroundColor="#1a3a5c"
                                     VerticalOptions="Center" CornerRadius="2"/>
                            <!-- خطوة 2 -->
                            <Border Grid.Column="2" WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="{Binding Sc2Bg}" StrokeThickness="0" StrokeShape="RoundRectangle 19">
                                <Label Text="{Binding Sc2Text}" TextColor="White"
                                       FontSize="15" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <BoxView Grid.Column="3" HeightRequest="3"
                                     BackgroundColor="{Binding Line23}"
                                     VerticalOptions="Center" CornerRadius="2"/>
                            <!-- خطوة 3 -->
                            <Border Grid.Column="4" WidthRequest="38" HeightRequest="38"
                                    BackgroundColor="{Binding Sc3Bg}" StrokeThickness="0" StrokeShape="RoundRectangle 19">
                                <Label Text="{Binding Sc3Text}" TextColor="White"
                                       FontSize="15" FontAttributes="Bold"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                        <Grid ColumnDefinitions="38,*,38,*,38">
                            <Label Grid.Column="0" Text="النوع" FontSize="11"
                                   TextColor="#1a3a5c" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                            <Label Grid.Column="2" Text="التفاصيل" FontSize="11"
                                   TextColor="#c8a53a" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsStep2}"/>
                            <Label Grid.Column="2" Text="التفاصيل" FontSize="11"
                                   TextColor="#1a3a5c" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsStep3}"/>
                            <Label Grid.Column="4" Text="الإرسال" FontSize="11"
                                   TextColor="#9ca3af" HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsStep2}"/>
                            <Label Grid.Column="4" Text="الإرسال" FontSize="11"
                                   TextColor="#c8a53a" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   IsVisible="{Binding IsStep3}"/>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ══════════ STEP 2 ══════════ -->
                    <VerticalStackLayout Spacing="14" IsVisible="{Binding IsStep2}">

                        <!-- 1. نوع المساهمة -->
                        <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Padding="16" Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="نوع المساهمة"
                                           FontSize="15" FontAttributes="Bold" TextColor="#1a3a5c"
                                           VerticalOptions="Center"/>
                                    <Border Grid.Column="1" WidthRequest="26" HeightRequest="26"
                                            BackgroundColor="#1a3a5c" StrokeThickness="0" StrokeShape="RoundRectangle 13">
                                        <Label Text="1" TextColor="White" FontSize="13" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="10" RowSpacing="10">
                                    <!-- هدية عينية -->
                                    <Border Grid.Row="0" Grid.Column="0"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 14" Padding="10,14">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </Style>
                                        </Border.Style>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[0].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#dbeafe"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                            <Border WidthRequest="44" HeightRequest="44"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    HorizontalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[0].IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="#1a3a5c"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[0].IsSelected}"
                                                                 Value="False">
                                                        <Setter Property="BackgroundColor" Value="#f3f4f6"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="🎁" FontSize="20"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="هدية عينية" FontSize="13" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                            <Label Text="أجهزة · ملابس" FontSize="11"
                                                   TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}"
                                                                  CommandParameter="{Binding ContribTypes[0]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <!-- مساهمة مالية -->
                                    <Border Grid.Row="0" Grid.Column="1"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 14" Padding="10,14">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[1].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#dbeafe"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[1].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                            <Border WidthRequest="44" HeightRequest="44"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    HorizontalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[1].IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="#1a3a5c"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[1].IsSelected}"
                                                                 Value="False">
                                                        <Setter Property="BackgroundColor" Value="#f3f4f6"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="💳" FontSize="20"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="مساهمة مالية" FontSize="13" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                            <Label Text="تحويل · بريد" FontSize="11"
                                                   TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}"
                                                                  CommandParameter="{Binding ContribTypes[1]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <!-- زيارة المكتب -->
                                    <Border Grid.Row="1" Grid.Column="0"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 14" Padding="10,14">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[2].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#dbeafe"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[2].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                            <Border WidthRequest="44" HeightRequest="44"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    HorizontalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[2].IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="#1a3a5c"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[2].IsSelected}"
                                                                 Value="False">
                                                        <Setter Property="BackgroundColor" Value="#f3f4f6"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="🏛️" FontSize="20"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="زيارة المكتب" FontSize="13" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                            <Label Text="تسليم مباشر" FontSize="11"
                                                   TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}"
                                                                  CommandParameter="{Binding ContribTypes[2]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <!-- لمريض محدد -->
                                    <Border Grid.Row="1" Grid.Column="1"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 14" Padding="10,14">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[3].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#dbeafe"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ContribTypes[3].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                            <Border WidthRequest="44" HeightRequest="44"
                                                    StrokeThickness="0" StrokeShape="RoundRectangle 12"
                                                    HorizontalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[3].IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="BackgroundColor" Value="#1a3a5c"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding ContribTypes[3].IsSelected}"
                                                                 Value="False">
                                                        <Setter Property="BackgroundColor" Value="#f3f4f6"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="🤲" FontSize="20"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <Label Text="لمريض محدد" FontSize="13" FontAttributes="Bold"
                                                   TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                            <Label Text="هدية شخصية" FontSize="11"
                                                   TextColor="#6b7280" HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}"
                                                                  CommandParameter="{Binding ContribTypes[3]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- 2. فئة النشاط -->
                        <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Padding="16" Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="فئة النشاط"
                                           FontSize="15" FontAttributes="Bold" TextColor="#1a3a5c"/>
                                    <Border Grid.Column="1" WidthRequest="26" HeightRequest="26"
                                            BackgroundColor="#1a3a5c" StrokeThickness="0" StrokeShape="RoundRectangle 13">
                                        <Label Text="2" TextColor="White" FontSize="13" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8" RowSpacing="8">
                                    <Border Grid.Row="0" Grid.Column="0"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 22" Padding="12,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[0].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#f0f4ff"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[0].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="التجهيزات الطبية" FontSize="13" FontAttributes="Bold"
                                               TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleCategoryCommand}"
                                                                  CommandParameter="{Binding ActivityCategories[0]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 22" Padding="12,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[1].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#f0f4ff"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[1].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="رعاية المرضى" FontSize="13" FontAttributes="Bold"
                                               TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleCategoryCommand}"
                                                                  CommandParameter="{Binding ActivityCategories[1]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="0"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 22" Padding="12,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[2].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#f0f4ff"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[2].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="عام للجمعية" FontSize="13" FontAttributes="Bold"
                                               TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleCategoryCommand}"
                                                                  CommandParameter="{Binding ActivityCategories[2]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border Grid.Row="1" Grid.Column="1"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 22" Padding="12,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[3].IsSelected}"
                                                         Value="True">
                                                <Setter Property="Stroke" Value="#1a3a5c"/>
                                                <Setter Property="BackgroundColor" Value="#f0f4ff"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding ActivityCategories[3].IsSelected}"
                                                         Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="تدريب المتطوعين" FontSize="13" FontAttributes="Bold"
                                               TextColor="#1a3a5c" HorizontalTextAlignment="Center"/>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleCategoryCommand}"
                                                                  CommandParameter="{Binding ActivityCategories[3]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- 3. المبلغ أو الشيء المُقدَّم -->
                        <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                            <VerticalStackLayout Padding="16" Spacing="14">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" Text="المبلغ أو الشيء المُقدَّم"
                                           FontSize="15" FontAttributes="Bold" TextColor="#1a3a5c"/>
                                    <Border Grid.Column="1" WidthRequest="26" HeightRequest="26"
                                            BackgroundColor="#1a3a5c" StrokeThickness="0" StrokeShape="RoundRectangle 13">
                                        <Label Text="3" TextColor="White" FontSize="13" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                                <!-- شرائح المبالغ -->
                                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8" RowSpacing="8">
                                    <Border Grid.Row="0" Grid.Column="2"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="6,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[0].IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="#c8a53a"/>
                                                <Setter Property="BackgroundColor" Value="#fffbeb"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[0].IsSelected}" Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="500 دج" FontSize="13" FontAttributes="Bold"
                                               HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[0].IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="#c8a53a"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[0].IsSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="#374151"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPresetCommand}" CommandParameter="{Binding AmountPresets[0]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="1"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="6,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[1].IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="#c8a53a"/>
                                                <Setter Property="BackgroundColor" Value="#fffbeb"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[1].IsSelected}" Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="1000 دج" FontSize="13" FontAttributes="Bold"
                                               HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[1].IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="#c8a53a"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[1].IsSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="#374151"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPresetCommand}" CommandParameter="{Binding AmountPresets[1]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Border Grid.Row="0" Grid.Column="0"
                                            StrokeThickness="1.5" StrokeShape="RoundRectangle 20" Padding="6,9">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[2].IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="#c8a53a"/>
                                                <Setter Property="BackgroundColor" Value="#fffbeb"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding AmountPresets[2].IsSelected}" Value="False">
                                                <Setter Property="Stroke" Value="#e5e7eb"/>
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="2000 دج" FontSize="13" FontAttributes="Bold"
                                               HorizontalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[2].IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="#c8a53a"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding AmountPresets[2].IsSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="#374151"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectPresetCommand}" CommandParameter="{Binding AmountPresets[2]}"/>
                                        </Border.GestureRecognizers>
                                    </Border>

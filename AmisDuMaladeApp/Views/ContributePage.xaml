                                                            <Span Text="رقم الحساب الجاري: "/>
                                                            <Span Text="0023456789 / مفتاح 78"
                                                                  FontAttributes="Bold" TextColor="#1a3a5c"/>
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                                <Label FontSize="12" TextColor="#374151">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="المستفيد: "/>
                                                            <Span Text="جمعية أصدقاء المريض – سكيكدة"
                                                                  FontAttributes="Bold" TextColor="#1a3a5c"/>

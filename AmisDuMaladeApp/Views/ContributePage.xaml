                                               Placeholder="05XX XX XX XX"
                                               PlaceholderColor="#9ca3af"
                                               Keyboard="Telephone"
                                               TextColor="#1a3a5c" FontSize="14"
                                               HorizontalTextAlignment="End"
                                               BackgroundColor="Transparent"/>
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>


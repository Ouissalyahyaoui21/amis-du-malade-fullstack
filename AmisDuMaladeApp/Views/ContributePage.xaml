                                                    </VerticalStackLayout>
                                                </HorizontalStackLayout>
                                                <HorizontalStackLayout Spacing="8">
                                                    <Label Text="●" TextColor="#c8a53a" FontSize="14" VerticalOptions="Start"/>
                                                    <VerticalStackLayout Spacing="2">
                                                        <Label Text="للتواصل" FontSize="12" FontAttributes="Bold" TextColor="#1a3a5c"/>
                                                        <Label Text="0551 000 000" FontSize="12" TextColor="#374151"/>
                                                    </VerticalStackLayout>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                    <Border.GestureRecognizers>

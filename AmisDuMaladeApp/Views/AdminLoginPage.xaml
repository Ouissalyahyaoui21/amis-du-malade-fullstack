<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AmisDuMaladeApp.ViewModels"
             xmlns:conv="clr-namespace:AmisDuMaladeApp.Converters"
             x:Class="AmisDuMaladeApp.Views.AdminLoginPage"
             x:DataType="vm:AdminLoginViewModel"
             Shell.NavBarIsVisible="False"
             FlowDirection="{Binding FlowDirection}"
             BackgroundColor="#1a3a5c">

    <ContentPage.Resources>
        <conv:BoolToColorConverter x:Key="TabBgConv"   TrueColor="White"    FalseColor="Transparent"/>
        <conv:BoolToColorConverter x:Key="TabTextConv" TrueColor="#1a3a5c"  FalseColor="#6b7280"/>
        <conv:BoolToColorConverter x:Key="CheckBgConv" TrueColor="#1a3a5c"  FalseColor="White"/>
        <conv:BoolToColorConverter x:Key="LockBgConv"  TrueColor="#8096ae"  FalseColor="#1a3a5c"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ══ TOP BAR ══ -->
        <Grid Grid.Row="0" BackgroundColor="#0f2236" Padding="16,10"
              ColumnDefinitions="Auto,*,Auto,Auto">

            <Border Grid.Column="0" BackgroundColor="#1f2e3d" StrokeThickness="0" Padding="10,5">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Label Text="ولاية سكيكدة" FontSize="11" TextColor="#d1d5db" FontAttributes="Bold"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="جمعية أصدقاء المريض" FontSize="14" TextColor="White"
                       FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                <Label Text="Association Amis du Malade – Skikda" FontSize="10"
                       TextColor="#c8a53a" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <Border Grid.Column="2" BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="8,5" Margin="0,0,6,0">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                    <Ellipse Fill="#22c55e" WidthRequest="8" HeightRequest="8" VerticalOptions="Center"/>
                    <Label Text="النظام شغال" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>

            <!-- زر الرئيسية -->
            <Border Grid.Column="3" BackgroundColor="#26ffffff" StrokeThickness="0"
                    Padding="8,5" VerticalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoHomeCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="🏠" FontSize="12"/>
                    <Label Text="الرئيسية" FontSize="11" TextColor="White" FontAttributes="Bold"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ══ HEADER ══ -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="#1a3a5c"
                             Padding="20,28,20,0" Spacing="10" HorizontalOptions="Center">

            <!-- Logo circle -->
            <Border WidthRequest="90" HeightRequest="90"
                    BackgroundColor="White" Stroke="#c8a53a" StrokeThickness="3"
                    HorizontalOptions="Center">
                <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="20" Opacity="0.3"/>
                </Border.Shadow>
                <Image Source="logo.png" Aspect="AspectFill"/>
            </Border>

            <Label Text="نظام إدارة الجمعية" FontSize="22" FontAttributes="Bold"
                   TextColor="White" HorizontalTextAlignment="Center"/>
            <Label Text="Association Amis du Malade – Skikda" FontSize="13"
                   TextColor="#c8a53a" HorizontalTextAlignment="Center"/>
            <Label Text="📍 ولاية سكيكدة · الجزائر" FontSize="12"
                   TextColor="#9ca3af" HorizontalTextAlignment="Center"/>

            <BoxView WidthRequest="48" HeightRequest="3" Color="#c8a53a" CornerRadius="2"
                     HorizontalOptions="Center" Margin="0,4,0,24"/>
        </VerticalStackLayout>

        <!-- ══ CARD ══ -->
        <ScrollView Grid.Row="2">
            <Border BackgroundColor="White" StrokeThickness="0" Padding="24,32,24,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28,28,0,0"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="0">

                    <!-- Greeting -->
                    <Label Text="👋" FontSize="36" HorizontalTextAlignment="Center" Margin="0,0,0,8"/>
                    <Label Text="أهلاً وسهلاً بك" FontSize="22" FontAttributes="Bold"
                           TextColor="#1a3a5c" HorizontalTextAlignment="Center" Margin="0,0,0,6"/>
                    <Label Text="نسعد بخدمتك – سجل دخولك للوصول إلى لوحة التحكم"
                           FontSize="13" TextColor="#6b7280" HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" Margin="0,0,0,24"/>

                    <!-- ── Tab switcher ── -->
                    <Border BackgroundColor="#f3f4f6" StrokeThickness="0"
                            Padding="4" Margin="0,0,0,20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="0">

                            <!-- Username tab (Column 0 = RIGHT in RTL) -->
                            <Border Grid.Column="0" StrokeThickness="0" Padding="10"
                                    BackgroundColor="{Binding IsUsernameTab, Converter={StaticResource TabBgConv}}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetUsernameTabCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="👤 اسم المستخدم" FontSize="13" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{Binding IsUsernameTab, Converter={StaticResource TabTextConv}}"/>
                            </Border>

                            <!-- Email tab (Column 1 = LEFT in RTL) -->
                            <Border Grid.Column="1" StrokeThickness="0" Padding="10"
                                    BackgroundColor="{Binding IsEmailTab, Converter={StaticResource TabBgConv}}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetEmailTabCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="📧 البريد الإلكتروني" FontSize="13" FontAttributes="Bold"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{Binding IsEmailTab, Converter={StaticResource TabTextConv}}"/>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- ── Error message ── -->
                    <Border IsVisible="{Binding HasLoginError}" BackgroundColor="#fef2f2"
                            Stroke="#fecaca" Padding="14,10" Margin="0,0,0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚠️" FontSize="13" VerticalOptions="Start"/>
                            <Label Text="{Binding LoginErrorText}" FontSize="13" TextColor="#dc2626"
                                   FontAttributes="Bold" LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ── Attempts warning ── -->
                    <Border IsVisible="{Binding ShowAttemptsWarning}" BackgroundColor="#fffbeb"
                            Stroke="#fde68a" Padding="14,10" Margin="0,0,0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🔒" FontSize="13" VerticalOptions="Start"/>
                            <Label Text="{Binding AttemptsWarningText}" FontSize="12" TextColor="#92400e"
                                   LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ── Email field ── -->
                    <VerticalStackLayout IsVisible="{Binding IsEmailTab}" Margin="0,0,0,16" Spacing="6">
                        <Label FontSize="13" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="* " TextColor="#dc2626"/>
                                    <Span Text="البريد الإلكتروني" TextColor="#374151"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border Stroke="#e5e7eb" StrokeThickness="1.5" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Text="{Binding Email}" Keyboard="Email"
                                       Placeholder="example@association-skikda.dz"
                                       PlaceholderColor="#9ca3af" TextColor="#1a3a5c"
                                       BackgroundColor="Transparent" FontSize="14"/>
                                <Label Grid.Column="1" Text="📧" FontSize="18" TextColor="#9ca3af"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Username field ── -->
                    <VerticalStackLayout IsVisible="{Binding IsUsernameTab}" Margin="0,0,0,16" Spacing="6">
                        <Label FontSize="13" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="* " TextColor="#dc2626"/>
                                    <Span Text="اسم المستخدم" TextColor="#374151"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border Stroke="#e5e7eb" StrokeThickness="1.5" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <Entry Grid.Column="0" Text="{Binding Username}"
                                       Placeholder="admin"
                                       PlaceholderColor="#9ca3af" TextColor="#1a3a5c"
                                       BackgroundColor="Transparent" FontSize="14"/>
                                <Label Grid.Column="1" Text="👤" FontSize="18" TextColor="#9ca3af"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Password field ── -->
                    <VerticalStackLayout Margin="0,0,0,16" Spacing="6">
                        <Label FontSize="13" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="* " TextColor="#dc2626"/>
                                    <Span Text="كلمة المرور" TextColor="#374151"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <Border Stroke="#e5e7eb" StrokeThickness="1.5" Padding="14,0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="4">
                                <Entry Grid.Column="0" Text="{Binding Password}"
                                       IsPassword="{Binding IsPasswordHidden}"
                                       Placeholder="••••••••"
                                       PlaceholderColor="#9ca3af" TextColor="#1a3a5c"
                                       BackgroundColor="Transparent" FontSize="14"/>
                                <Label Grid.Column="1" Text="{Binding PasswordToggleIcon}"
                                       FontSize="18" TextColor="#9ca3af" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding TogglePasswordCommand}"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="2" Text="🔑" FontSize="18" TextColor="#9ca3af"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ── Options row (Forgot + Remember me) ── -->
                    <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,20">

                        <!-- Col 0 (RIGHT in RTL): Forgot link -->
                        <Label Grid.Column="0" Text="نسيت كلمة المرور؟" FontSize="13"
                               TextColor="#dc2626" TextDecorations="Underline" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShowForgotPasswordCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>

                        <!-- Col 1 (LEFT in RTL): Remember me -->
                        <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="8">
                            <HorizontalStackLayout.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleRememberMeCommand}"/>
                            </HorizontalStackLayout.GestureRecognizers>
                            <Label Text="تذكرني لمدة 7 أيام" FontSize="13" TextColor="#374151"
                                   VerticalOptions="Center"/>
                            <Border WidthRequest="20" HeightRequest="20"
                                    StrokeThickness="2" Stroke="#1a3a5c" VerticalOptions="Center"
                                    BackgroundColor="{Binding RememberMe, Converter={StaticResource CheckBgConv}}">
                                <Border.StrokeShape><RoundRectangle CornerRadius="6"/></Border.StrokeShape>
                                <Label Text="✓" FontSize="12" TextColor="White"
                                       HorizontalTextAlignment="Center" VerticalTextAlignment="Center"
                                       IsVisible="{Binding RememberMe}"/>
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- ── Login button ── -->
                    <Border Margin="0,0,0,14" StrokeThickness="0"
                            BackgroundColor="{Binding IsLocked, Converter={StaticResource LockBgConv}}">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LoginCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Padding="0,16">
                            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                               Color="White" WidthRequest="18" HeightRequest="18"
                                               VerticalOptions="Center"/>
                            <Label FontSize="17" FontAttributes="Bold" TextColor="White" VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Text" Value="جارٍ التحقق..."/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsBusy}" Value="False">
                                        <Setter Property="Text" Value="🔒 تسجيل الدخول"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ── SSL note ── -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                        <Label Text="🔒" FontSize="12" TextColor="#9ca3af"/>
                        <Label Text="اتصال مشفر SSL/TLS – بياناتك محمية" FontSize="12" TextColor="#9ca3af"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </ScrollView>

        <!-- ══ FOOTER ══ -->
        <VerticalStackLayout Grid.Row="3" BackgroundColor="#0f2236" Padding="20,16" Spacing="10">
            <Label Text="© 2025 جمعية أصدقاء المريض – سكيكدة · جميع الحقوق محفوظة"
                   FontSize="11" TextColor="#6b7280" HorizontalTextAlignment="Center"/>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="12">
                <Border BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="10,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                    <Label Text="v2.1.0" FontSize="11" TextColor="#c8a53a" FontAttributes="Bold"/>
                </Border>
                <Label Text="سياسة الخصوصية" FontSize="11" TextColor="#9ca3af" TextDecorations="Underline"/>
                <Label Text="الدعم التقني" FontSize="11" TextColor="#9ca3af" TextDecorations="Underline"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- ══ FORGOT PASSWORD DIALOG OVERLAY ══ -->
        <Grid Grid.RowSpan="4" BackgroundColor="#80000000" IsVisible="{Binding ShowForgotDialog}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseForgotDialogCommand}"/>
            </Grid.GestureRecognizers>
            <Border BackgroundColor="White" StrokeThickness="0" Padding="24"
                    WidthRequest="320" VerticalOptions="Center" HorizontalOptions="Center">
                <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                <Border.GestureRecognizers>
                    <!-- Absorb taps so overlay behind doesn't close -->
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="0">
                    <Label Text="🔑 نسيت كلمة المرور؟" FontSize="17" FontAttributes="Bold"
                           TextColor="#1a3a5c" Margin="0,0,0,8"/>
                    <Label Text="للحصول على رابط إعادة تعيين كلمة المرور، تواصل مع مدير النظام عبر البريد الإلكتروني:"
                           FontSize="13" TextColor="#6b7280" LineBreakMode="WordWrap" Margin="0,0,0,20"/>
                    <Border BackgroundColor="#f0f4ff" StrokeThickness="0" Padding="12" Margin="0,0,0,20">
                        <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                        <Label Text="admin@association-skikda.dz" FontSize="13"
                               TextColor="#1a3a5c" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
                    </Border>
                    <Border BackgroundColor="#1a3a5c" StrokeThickness="0" Padding="0,12">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseForgotDialogCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="حسناً، شكراً" FontSize="14" FontAttributes="Bold"
                               TextColor="White" HorizontalTextAlignment="Center"/>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
